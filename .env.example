# === RUNTIME ===
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# === DATABASE (Supabase Postgres) ===
# Get from: Supabase Dashboard → Settings → Database → Connection String
# DATABASE_URL: Use "Transaction" pooler URL (port 6543, includes ?pgbouncer=true)
# DIRECT_URL: Use Session pooler or direct connection (port 5432) — used only by Prisma for migrations
DATABASE_URL=
DIRECT_URL=

# === SUPABASE AUTH (REQUIRED) ===
# Project Settings → API in Supabase dashboard.
# SUPABASE_URL: 'https://<project-ref>.supabase.co'
# SUPABASE_ANON_KEY: anon/public key (safe to expose to frontend)
# SUPABASE_SERVICE_ROLE_KEY: server-only secret — never commit, never expose
#
# Every protected route requires a valid JWT issued by this project. There is
# no longer an x-api-key / x-admin-key fallback.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === EXTERNAL APIS ===
# Get free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# === CORS ===
ALLOWED_ORIGINS=http://localhost:3000

JBLANKED_API_KEY =
